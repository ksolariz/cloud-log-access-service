# Leave unset to use the Vite dev proxy (see vite.config.js), which forwards
# /api/* to VITE_BACKEND_ORIGIN. Set this instead if you want the browser to
# call the backend directly (e.g. in production, behind nginx).
# VITE_API_URL=http://localhost:8000

# Used by the dev proxy only (server-side, not exposed to the browser).
VITE_BACKEND_ORIGIN=http://backend:8000
VITE_API_URL=http://localhost:8000/api
